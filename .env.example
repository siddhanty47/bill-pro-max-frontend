# =============================================================================
# Environment Configuration - Local vs Production Backend
# =============================================================================
#
# Use separate env files for each environment. No need to edit files to switch.
#
#   npm run dev      → uses .env.development (local backend)
#   npm run dev:prod → uses .env.prod (production backend)
#
# =============================================================================

# -----------------------------------------------------------------------------
# .env.development - Local backend (npm run dev)
# -----------------------------------------------------------------------------
# Copy to .env.development and customize:
#
# VITE_API_URL=                    # Leave empty to use Vite proxy
# VITE_KEYCLOAK_URL=http://localhost:8080
# VITE_KEYCLOAK_REALM=billpromax
# VITE_KEYCLOAK_CLIENT_ID=billpromax-frontend
# VITE_WS_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# .env.prod - Production backend (npm run dev:prod)
# -----------------------------------------------------------------------------
# Copy to .env.prod and customize:
#
# VITE_API_URL=https://your-backend.onrender.com/api/v1
# VITE_KEYCLOAK_URL=https://your-keycloak.onrender.com
# VITE_KEYCLOAK_REALM=billpromax
# VITE_KEYCLOAK_CLIENT_ID=billpromax-frontend
# VITE_WS_URL=https://your-backend.onrender.com
